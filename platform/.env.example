# Clean Row Platform — Environment Variables
# Copy to .env and fill in your values

# Postgres password (used by docker-compose and backend)
POSTGRES_PASSWORD=cleanrow_dev

# Ollama endpoint — if ollama runs on the host machine:
# Linux: host-gateway resolves to the Docker host automatically
OLLAMA_URL=http://host-gateway:11434

# CORS origins — comma-separated; keep * for local tablet use
CORS_ORIGINS=*

# Secret key for any future auth (change this for production)
SECRET_KEY=change-me-in-production

# Port overrides — change if something else is already on these ports
# Your AI hub has SillyTavern on 8000, so backend defaults to 8010
BACKEND_PORT=8010
WEB_PORT=3000
POSTGRES_PORT=5433
